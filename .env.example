# Copia este archivo a .env.local y rellena los valores.

# --- Base de datos (Neon) ---------------------------------------------------
# Cadena de conexión del rol OWNER (la integración de Neon en Vercel la inyecta
# en producción). En local, cópiala desde el panel de Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# --- Neon Auth (Better Auth) ------------------------------------------------
# URL base del servidor de Neon Auth de tu proyecto.
NEON_AUTH_BASE_URL="https://..."
# Secreto para firmar las cookies de sesión (genera uno largo y aleatorio).
NEON_AUTH_COOKIE_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# --- App --------------------------------------------------------------------
# URL pública de la app (para los enlaces de los emails de invitación/reset).
# En local: http://localhost:3000 ; en prod: https://jateam-scoring.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
